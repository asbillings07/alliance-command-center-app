generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AllianceRole {
  OWNER
  ADMIN
  LEADER
  VIEWER
}

enum Metric_Type {
  NUMERIC
  BOOLEAN
}

enum LeadershipNoteType {
  POSITIVE
  WARNING
  OBSERVATION
  PROMOTION
}

enum LeadershipNoteVisibility {
  LEADERSHIP
  ADMIN
}

enum FeedbackCategory {
  BUG
  IDEA
  CONFUSING
}

model Alliance {
  id        String   @id @default(cuid())
  name      String
  server    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  allianceMembers  AllianceMember[]
  metrics          Metric[]
  memberships      AllianceMembership[]
  metricPeriods    MetricPeriod[]
  invitations      Invitation[]
  betaInvitations  BetaInvitation[]
  @@unique([name, server])
}

model AllianceMembership {
  id String @id @default(cuid())

  allianceId String
  alliance Alliance @relation(fields: [allianceId], references: [id])

  userId String
  user User @relation(fields: [userId], references: [id])

  role AllianceRole

  createdAt DateTime @default(now())

  @@unique([allianceId, userId])
}

model AllianceMember {
  id          String    @id @default(cuid())
  allianceId  String
  playerName  String
  discordName String?
  thp         Int?
  squadPower  Int?
  role        String?
  joinedAt    DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  
  alliance    Alliance  @relation(fields: [allianceId], references: [id])
  metricEntries MemberMetricEntry[]
  leadershipNotes LeadershipNote[]
  invitations Invitation[]

  @@unique([allianceId, playerName])
  @@index([allianceId, archivedAt])
  @@index([allianceId, userId])
}

model User {
  id          String @id @default(cuid())
  preferredLanguage String @default("en")
  email       String @unique
  displayName String
  // Authentication capabilities are modeled as the presence of provider-specific
  // credentials, not a mutually exclusive provider enum. A user may have both,
  // enabling password + Google on the same canonical identity (email). See ADR-013.
  passwordHash String?
  googleSubject String? @unique
  isPlatformAdmin Boolean @default(false)

  memberships AllianceMembership[]
  authoredNotes LeadershipNote[]
  linkedMembers AllianceMember[]
  invitationsSent Invitation[] @relation("InvitationsSent")
  invitationsAccepted Invitation[] @relation("InvitationsAccepted")
  betaInvitationsAccepted BetaInvitation[] @relation("BetaInvitationsAccepted")
  feedback Feedback[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Metric {
  id String @id @default(cuid())

  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id])
  name        String
  description String?

  type   Metric_Type
  active Boolean @default(true)

  periodMetrics MetricPeriodMetric[]

  createdAt DateTime @default(now())
  @@unique([allianceId, name])
}

model MetricPeriod {
  id String @id @default(cuid())

  allianceId String
  alliance Alliance @relation(fields: [allianceId], references: [id])

  name String

  active Boolean @default(true)

  startsAt DateTime?
  endsAt DateTime?

  periodMetrics MetricPeriodMetric[]

  createdAt DateTime @default(now())
}

model MetricPeriodMetric {
  periodId String
  period MetricPeriod @relation(fields: [periodId], references: [id])

  metricId String
  metric Metric @relation(fields: [metricId], references: [id])

  weight Int
  required Boolean
  active Boolean @default(true)

  memberMetricEntries MemberMetricEntry[]

  @@id([periodId, metricId])
}

model MemberMetricEntry {
  id String @id @default(cuid())

  allianceMemberId String
  allianceMember   AllianceMember @relation(fields: [allianceMemberId], references: [id])

  periodId String
  metricId String
  periodMetric MetricPeriodMetric @relation(fields: [periodId, metricId], references: [periodId, metricId])

  value Int

  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([allianceMemberId, periodId])
  @@index([metricId])
}

model LeadershipNote {
  id String @id @default(cuid())

  allianceMemberId String
  allianceMember AllianceMember @relation(fields: [allianceMemberId], references: [id])

  authorId String
  author User @relation(fields: [authorId], references: [id])

  noteType LeadershipNoteType
  visibility LeadershipNoteVisibility
  title String?
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Invitation {
  id String @id @default(cuid())
  
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id])
  
  invitedById String
  invitedBy   User @relation("InvitationsSent", fields: [invitedById], references: [id])
  
  allianceMemberId   String?
  allianceMember     AllianceMember? @relation(fields: [allianceMemberId], references: [id])
  playerNameSnapshot String
  
  email          String
  membershipRole AllianceRole
  token          String  @unique
  code           String? @unique
  
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  acceptedByUser   User? @relation("InvitationsAccepted", fields: [acceptedByUserId], references: [id])
  cancelledAt      DateTime?
  
  createdAt DateTime @default(now())
  
  @@index([allianceId, email])
}

model BetaInvitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  code      String   @unique
  notes     String?
  campaign  String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  issuedAt  DateTime @default(now())

  acceptedAt       DateTime?
  acceptedByUserId String?
  acceptedByUser   User?     @relation("BetaInvitationsAccepted", fields: [acceptedByUserId], references: [id])

  revokedAt DateTime?

  allianceId String?
  alliance   Alliance? @relation(fields: [allianceId], references: [id])

  @@index([email])
}

// A prospective user expressing interest in the beta. Intentionally separate
// from the invitation model (ADR-014 keeps notification vs. domain concerns
// distinct): an access request is not an invitation, it merely captures
// interest. An administrator later reviews requests and issues invitations
// through the existing invitation flow. Kept deliberately minimal for beta;
// status/approval workflow can be layered on later without a redesign.
model AccessRequest {
  id           String   @id @default(cuid())
  name         String
  email        String
  allianceName String?
  message      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// In-app feedback captured from an authenticated user while friction is fresh.
// The row stores facts (message + client/context metadata); alliance/period
// context is derived from the URL only when building the operator notification
// (ADR-014 keeps notification concerns out of persistence). Deliberately
// minimal for beta: no status/triage workflow, no attachments.
model Feedback {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  category   FeedbackCategory
  message    String
  url        String
  userAgent  String?
  viewport   String?
  appVersion String?
  createdAt  DateTime         @default(now())

  @@index([createdAt])
}
