# Alliance Command Center - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Connection string for PostgreSQL database
# For local development: postgresql://postgres:postgres@localhost:5232/postgres
# For production: Use your managed PostgreSQL provider (Neon, Supabase, RDS)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Optional direct (non-pooled) connection string. Prisma uses this for
# migrations when a pooler sits in front of DATABASE_URL. Validated by the same
# isolation guard as DATABASE_URL (ADR-016).
# DIRECT_URL="postgresql://user:password@host:5432/database"

# -----------------------------------------------------------------------------
# Database isolation (ADR-016) - REQUIRED on Vercel (production + preview)
# -----------------------------------------------------------------------------
# Comma/whitespace-separated allowlist identifying the PRODUCTION database.
# Accepts Neon endpoint ids (e.g. ep-cool-name-123456), hosts, or full URLs;
# pooled/direct forms are normalized to the same endpoint id. Startup fails
# closed if a Vercel Production deploy is NOT on a listed identity, or if a
# Vercel Preview deploy IS - so a preview can never read/mutate production data.
# For a NON-Neon host, the identity includes the port when one is present in
# DATABASE_URL/DIRECT_URL (e.g. "db.example.com:5432", not just
# "db.example.com") - list the host WITH its port here too, or the identity
# won't match and Vercel startup will fail. Neon hosts are unaffected: the
# endpoint id is already port-independent.
# PRODUCTION_DB_HOSTS="ep-cool-name-123456"

# =============================================================================
# AUTHENTICATION (Auth.js / NextAuth)
# =============================================================================
# Secret for signing sessions - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Base URL for authentication callbacks and invite links. This is the single
# canonical origin for Auth.js callbacks, invitation/reset/feedback links, and
# emails - keep it to ONE host (no trailing slash).
# Local: http://localhost:3000
# Production: https://alliancehqapp.com  (www redirects to the apex)
NEXTAUTH_URL="http://localhost:3000"

# Trust the host header (required for Vercel and reverse proxies)
# Set to "true" in production
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# Google OAuth (optional)
# -----------------------------------------------------------------------------
# "Continue with Google" is enabled only when BOTH values below are set, so
# local/CI environments without credentials are unaffected.
#
# Create an OAuth 2.0 Web Application in Google Cloud Console:
#   Authorized JavaScript origin (production): https://alliancehqapp.com
#   Authorized redirect URI (local):           http://localhost:3000/api/auth/callback/google
#   Authorized redirect URI (production):       https://alliancehqapp.com/api/auth/callback/google
#
# Auth.js reads these names automatically.
# AUTH_GOOGLE_ID="your-google-oauth-client-id"
# AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# =============================================================================
# TRANSACTIONAL EMAIL (optional)
# =============================================================================
# Beta invitation emails are sent only when BOTH values below are set. When
# unset (local/CI), the app logs the rendered email to the console instead of
# sending, so development works without a provider.
#
# RESEND_API_KEY: create at https://resend.com/api-keys
# EMAIL_FROM: the sender address.
#   - Quick local testing (no domain needed): onboarding@resend.dev
#     (only delivers to the email that owns your Resend account)
#   - Production: verify a domain in Resend and use e.g. noreply@alliancehqapp.com
# RESEND_API_KEY="re_your_api_key"
# EMAIL_FROM="AllianceHQ <noreply@alliancehqapp.com>"
#
# Preview isolation (ADR-016): a Vercel Preview deployment never sends
# unrestricted mail. Even with a Resend key, Preview logs (does not send)
# unless PREVIEW_EMAIL_ALLOWLIST names approved testers; only those exact
# recipients receive real email. Use a SEPARATE Preview Resend credential.
# PREVIEW_EMAIL_ALLOWLIST="you@example.com, teammate@example.com"

# =============================================================================
# BETA FEEDBACK (optional)
# =============================================================================
# Where in-app feedback notifications are emailed. Falls back to the first
# PLATFORM_ADMIN_EMAILS entry when unset. Delivery is best-effort (never blocks
# the submission).
# FEEDBACK_NOTIFICATION_EMAIL="you@alliancehqapp.com"

# Build identifier shown in feedback submissions. CI/CD should set this (e.g. a
# semver or "1.0.0-beta.1+<sha>"); locally it falls back to package.json.
# NEXT_PUBLIC_APP_VERSION="1.0.0-beta.1"

# =============================================================================
# PLATFORM ADMINISTRATION
# =============================================================================
# Comma-separated list of emails that have platform admin access
# These users can access /platform/* routes for operational visibility
PLATFORM_ADMIN_EMAILS="admin@example.com"

# Secret required to initialize the platform (create the first platform admin).
# Knowing an allowed email is NOT enough to bootstrap a fresh deployment; the
# operator must also supply this secret on the /initialize form.
# Generate with: openssl rand -base64 32
# Required in production. If unset, bootstrap is refused in production and
# allowed without a secret only in development/test.
PLATFORM_BOOTSTRAP_SECRET="your-bootstrap-secret-generate-with-openssl"

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================
# Enable/disable features without code changes
# All feature flags default to false (disabled)
# FEATURE_PLATFORM_CONSOLE="true"  # Platform operations console
# FEATURE_RECOGNITION="false"       # Member recognition system
# FEATURE_DISCORD="false"           # Discord integration features
# FEATURE_ANALYTICS="false"         # Analytics and reporting features

# =============================================================================
# ERROR TRACKING (optional, recommended for production)
# =============================================================================
# Sentry DSN for server-side error tracking
# Get this from your Sentry project settings
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Sentry DSN for client-side error tracking (must use NEXT_PUBLIC_ prefix)
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Enable Session Replay (captures user interactions, can include sensitive data)
# Only enable when explicitly needed for debugging
# NEXT_PUBLIC_SENTRY_REPLAY="false"

# Sentry auth token for sourcemap uploads during build
# SENTRY_AUTH_TOKEN="sntrys_eyJpYXQiOjE3ODQyN"