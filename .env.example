# Alliance Command Center - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Connection string for PostgreSQL database
# For local development: postgresql://postgres:postgres@localhost:5232/postgres
# For production: Use your managed PostgreSQL provider (Neon, Supabase, RDS)
DATABASE_URL="postgresql://user:password@host:5432/database"

# =============================================================================
# AUTHENTICATION (Auth.js / NextAuth)
# =============================================================================
# Secret for signing sessions - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Base URL for authentication callbacks and invite links
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Trust the host header (required for Vercel and reverse proxies)
# Set to "true" in production
AUTH_TRUST_HOST="true"

# =============================================================================
# PLATFORM ADMINISTRATION
# =============================================================================
# Comma-separated list of emails that have platform admin access
# These users can access /platform/* routes for operational visibility
PLATFORM_ADMIN_EMAILS="admin@example.com"

# Secret required to initialize the platform (create the first platform admin).
# Knowing an allowed email is NOT enough to bootstrap a fresh deployment; the
# operator must also supply this secret on the /initialize form.
# Generate with: openssl rand -base64 32
# Required in production. If unset, bootstrap is refused in production and
# allowed without a secret only in development/test.
PLATFORM_BOOTSTRAP_SECRET="your-bootstrap-secret-generate-with-openssl"

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================
# Enable/disable features without code changes
# All feature flags default to false (disabled)
# FEATURE_PLATFORM_CONSOLE="true"  # Platform operations console
# FEATURE_RECOGNITION="false"       # Member recognition system
# FEATURE_DISCORD="false"           # Discord integration features
# FEATURE_ANALYTICS="false"         # Analytics and reporting features

# =============================================================================
# ERROR TRACKING (optional, recommended for production)
# =============================================================================
# Sentry DSN for server-side error tracking
# Get this from your Sentry project settings
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Sentry DSN for client-side error tracking (must use NEXT_PUBLIC_ prefix)
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# Enable Session Replay (captures user interactions, can include sensitive data)
# Only enable when explicitly needed for debugging
# NEXT_PUBLIC_SENTRY_REPLAY="false"

# Sentry auth token for sourcemap uploads during build
# SENTRY_AUTH_TOKEN="sntrys_eyJpYXQiOjE3ODQyN"