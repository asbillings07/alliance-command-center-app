# Alliance Command Center - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Connection string for PostgreSQL database
# For local development: postgresql://postgres:postgres@localhost:5232/postgres
# For production: Use your managed PostgreSQL provider (Neon, Supabase, RDS)
DATABASE_URL="postgresql://user:password@host:5432/database"

# =============================================================================
# AUTHENTICATION (Auth.js / NextAuth)
# =============================================================================
# Secret for signing sessions - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Base URL for authentication callbacks and invite links
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Trust the host header (required for Vercel and reverse proxies)
# Set to "true" in production
AUTH_TRUST_HOST="true"

# =============================================================================
# PLATFORM ADMINISTRATION
# =============================================================================
# Comma-separated list of emails that have platform admin access
# These users can access /platform/* routes for operational visibility
PLATFORM_ADMIN_EMAILS="admin@example.com"

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================
# Enable/disable features without code changes
# FEATURE_PLATFORM_CONSOLE="true"
# FEATURE_RECOGNITION="false"

# =============================================================================
# ERROR TRACKING (optional, recommended for production)
# =============================================================================
# Sentry DSN for error tracking
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SENTRY_AUTH_TOKEN="sntrys_eyJpYXQiOjE3ODQyN"