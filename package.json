{
  "name": "alliance-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --dir app/src",
    "test:integration": "vitest run --dir app/src --testNamePattern integration",
    "test:e2e": "tsx ./node_modules/@playwright/test/cli.js test --project=application --grep-invert \"@visual|@a11y\"",
    "test:e2e:bootstrap": "prisma migrate reset --force --skip-seed && tsx ./node_modules/@playwright/test/cli.js test --project=bootstrap",
    "test:a11y": "tsx ./node_modules/@playwright/test/cli.js test --project=application --grep @a11y",
    "test:visual": "tsx ./node_modules/@playwright/test/cli.js test --project=application --grep @visual",
    "test:ci:quick": "npm run typecheck && npm run lint && npm run test:unit",
    "test:ci": "npm run typecheck && npm run lint && npm run test:unit && npm run test:integration && npx prisma migrate deploy && npx tsx prisma/seed.ts --write-env && npm run build && CI=true npm run test:e2e && CI=true npm run test:a11y",
    "seedDb": "tsx prisma/seed.ts",
    "migrateDev": "prisma migrate dev",
    "migrateProd": "prisma migrate deploy",
    "studio": "prisma studio",
    "generate": "prisma generate",
    "updateDb": "prisma db push",
    "syncDevDb": "prisma generate && prisma db push",
    "db:init": "docker compose up -d && sleep 10 && npm run syncDevDb && npm run seedDb",
    "beta:invite": "tsx scripts/create-beta-invite.ts",
    "e2e:setup": "tsx scripts/setup-e2e-env.ts",
    "e2e": "tsx ./node_modules/@playwright/test/cli.js test",
    "e2e:ui": "tsx ./node_modules/@playwright/test/cli.js test --ui",
    "e2e:headed": "tsx ./node_modules/@playwright/test/cli.js test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.66.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
